# Copy this file to .env and fill in your values
# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/your_db_name
# Secret for signing JWT tokens (use a long random string in production)
JWT_SECRET=your_jwt_secret_key_change_in_production
PORT=5000

# Comma-separated list of allowed frontend origins (Vercel domains)
# Example:
# CORS_ORIGIN=https://your-frontend.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=
